  const PROXIES = [
    {name:'direct', build:url=>url},
    {name:'allorigins', build:url=>'https://api.allorigins.win/raw?url='+encodeURIComponent(url)},
    {name:'corsproxy', build:url=>'https://corsproxy.io/?'+encodeURIComponent(url)},
    {name:'codetabs', build:url=>'https://api.codetabs.com/v1/proxy/?quest='+encodeURIComponent(url)},
    {name:'thingproxy', build:url=>'https://thingproxy.freeboard.io/fetch/'+url}
  ];

  async function fetchAny(target,{type='json', timeout=14000, quiet=false}={}){
    const controllers = [];
    const attempts = PROXIES.map(p => new Promise((resolve, reject) => {
      const controller = new AbortController();
      controllers.push(controller);
      const timer = setTimeout(() => controller.abort(), timeout);
      fetch(p.build(target), {
        signal: controller.signal,
        cache: 'no-store',
        headers: {'Accept': type === 'json' ? 'application/json,text/plain,*/*' : 'text/plain,*/*'}
      }).then(async res => {
        if(!res.ok) throw new Error('HTTP '+res.status);
        const data = type === 'text' ? await res.text() : await res.json();
        resolve({data, via:p.name});
      }).catch(reject).finally(() => clearTimeout(timer));
    }));
    try{
      const result = await Promise.any(attempts);
      controllers.forEach(c => { try{ c.abort(); }catch(_){} });
      return result;
    }catch(e){
      if(!quiet) state.errors.push(target.replace(/^https?:\/\//,'').slice(0,85)+': nicht erreichbar');
      throw e;
    }
  }

  async function yahooQuotes(symbols){
    const url = 'https://query1.finance.yahoo.com/v7/finance/quote?symbols=' + encodeURIComponent(symbols.join(','));
    try{
      const {data, via} = await fetchAny(url, {type:'json', timeout:15000});
      const arr = data && data.quoteResponse && Array.isArray(data.quoteResponse.result) ? data.quoteResponse.result : [];
      if(!arr.length) throw new Error('Keine Yahoo-Quotes');
      return arr.map(q => ({symbol:q.symbol, price:q.regularMarketPrice, change:q.regularMarketChange, changePct:q.regularMarketChangePercent, previousClose:q.regularMarketPreviousClose, volume:q.regularMarketVolume, currency:q.currency, marketState:q.marketState, exchange:q.fullExchangeName || q.exchange, marketTime:q.regularMarketTime ? new Date(q.regularMarketTime*1000).toISOString() : null, via, ok:true}));
    }catch(e){
      return yahooCharts(symbols);
    }
  }

  async function yahooCharts(symbols){
    const out = [];
    const queue = symbols.slice();
    async function worker(){
      while(queue.length){
        const symbol = queue.shift();
        const url = 'https://query1.finance.yahoo.com/v8/finance/chart/'+encodeURIComponent(symbol)+'?range=1d&interval=5m&includePrePost=false';
        try{
          const {data, via} = await fetchAny(url, {type:'json', timeout:15000, quiet:true});
          const result = data && data.chart && data.chart.result && data.chart.result[0];
          if(!result) throw new Error('Keine Chartdaten');
          const meta = result.meta || {}; const q = result.indicators && result.indicators.quote && result.indicators.quote[0] || {};
          const closes = (result.indicators && result.indicators.quote && result.indicators.quote[0] && result.indicators.quote[0].close || []).filter(v=>Number.isFinite(Number(v)));
          const price = safeNum(meta.regularMarketPrice) ?? closes[closes.length-1] ?? null;
          const prev = safeNum(meta.chartPreviousClose) ?? safeNum(meta.previousClose);
          const change = price!==null && prev!==null ? price-prev : null;
          const changePct = price!==null && prev ? (price-prev)/prev*100 : null;
          const volume = Array.isArray(q.volume) ? q.volume.filter(v=>Number.isFinite(Number(v))).reduce((a,b)=>a+Number(b),0) : null;
          out.push({symbol, price, change, changePct, previousClose:prev, volume, currency:meta.currency, marketState:meta.marketState, exchange:meta.exchangeName, marketTime:meta.regularMarketTime ? new Date(meta.regularMarketTime*1000).toISOString() : new Date().toISOString(), via, ok:true});
        }catch(e){out.push({symbol, ok:false, error:e.message || 'nicht geladen'});}
      }
    }
    await Promise.all(Array.from({length:5}, worker));
    return out;
  }

  async function updateMarket(){
    const allSymbols = [...STOCKS.map(x=>x.symbol), ...MACROS.map(x=>x.symbol)];
    const quotes = await yahooQuotes(allSymbols);
    const bySym = new Map(quotes.map(q=>[q.symbol,q]));
    const now = new Date().toISOString();
    state.stocks = STOCKS.map(meta => ({...meta, ...(bySym.get(meta.symbol)||{}), updatedAt:now}));
    state.macros = MACROS.map(meta => ({...meta, ...(bySym.get(meta.symbol)||{}), updatedAt:now}));
  }

  async function updateJetFuel(){
    const url = 'https://fred.stlouisfed.org/graph/fredgraph.csv?id=JETFUELUSGULF';
    try{
      const {data, via} = await fetchAny(url, {type:'text', timeout:15000, quiet:true});
      const rows = data.trim().split(/\r?\n/).slice(1).map(r=>r.split(',')).filter(r=>r.length>=2 && r[1] !== '.').map(r=>({date:r[0], value:Number(r[1])})).filter(r=>Number.isFinite(r.value));
      const last = rows[rows.length-1], prev = rows[rows.length-2];
      state.jetFuel = last ? {ok:true, name:'Jet Fuel Spot', value:last.value, date:last.date, changePct:prev ? (last.value-prev.value)/prev.value*100 : null, via, updatedAt:new Date().toISOString()} : null;
    }catch(e){state.jetFuel = null;}
  }

  function inBox(s,box){const lon=s[5],lat=s[6];return Number.isFinite(lon)&&Number.isFinite(lat)&&lat>=box.lamin&&lat<=box.lamax&&lon>=box.lomin&&lon<=box.lomax;}
  async function updateOps(){
    const url = 'https://opensky-network.org/api/states/all?lamin=35&lomin=-11&lamax=72&lomax=33';
    try{
      const {data, via} = await fetchAny(url,{type:'json',timeout:15000,quiet:true});
      const states = Array.isArray(data.states) ? data.states : [];
      const airborne = states.filter(s=>s && s[8]===false).length;
      const de = states.filter(s=>s && s[8]===false && inBox(s,{lamin:47.2,lomin:5.5,lamax:55.2,lomax:15.4})).length;
      const at = states.filter(s=>s && s[8]===false && inBox(s,{lamin:46.3,lomin:9.4,lamax:49.2,lomax:17.3})).length;
      state.opensky = {ok:true, airborne, de, at, via, updatedAt:new Date().toISOString()};
    }catch(e){state.opensky = null;}
  }

  async function updateMetar(){
    const ids = AIRPORTS.map(a=>a.id).join(',');
    const url = 'https://aviationweather.gov/api/data/metar?ids='+encodeURIComponent(ids)+'&format=json';
    try{
      const {data, via} = await fetchAny(url,{type:'json',timeout:15000,quiet:true});
      const arr = Array.isArray(data) ? data : [];
      state.metars = AIRPORTS.map(a=>{
        const m = arr.find(x=>x.icaoId===a.id || x.station_id===a.id) || {};
        const raw = m.rawOb || m.raw_text || '';
        return raw ? {ok:true, id:a.id, name:a.name, category:m.flightCategory || m.flight_category || '–', temp:m.temp ?? m.temp_c, wind:m.wspd ?? m.wind_speed_kt ?? '–', visib:m.visib ?? m.visibility_statute_mi ?? '–', raw, via, updatedAt:new Date().toISOString()} : {ok:false,id:a.id,name:a.name,error:'kein METAR'};
      });
    }catch(e){state.metars = AIRPORTS.map(a=>({ok:false,id:a.id,name:a.name,error:'nicht geladen'}));}
  }

  function saveCache(){try{localStorage.setItem(CACHE_KEY, JSON.stringify({stocks:state.stocks, macros:state.macros, jetFuel:state.jetFuel, opensky:state.opensky, metars:state.metars, lastUpdate:state.lastUpdate}));}catch(_){}}
  function loadCache(){try{const c=JSON.parse(localStorage.getItem(CACHE_KEY));if(c && (c.stocks||c.macros)){Object.assign(state,c,{fromCache:true});renderAll();return true;}}catch(_){} return false;}

  async function updateDashboard(manual=false){
    setLoading(true); state.errors=[]; state.fromCache=false;
    try{
      await Promise.allSettled([updateMarket(), updateJetFuel(), updateOps(), updateMetar()]);
      const liveOk = loadedCount(state.stocks)+loadedCount(state.macros)+(state.jetFuel?1:0)+(state.opensky?1:0)+state.metars.filter(x=>x.ok).length;
      if(liveOk===0 && loadCache()){
        state.fromCache = true;
        if(manual) toast('Gerade keine Live-Werte erreichbar. Letzter Stand bleibt sichtbar.');
      } else {
        state.lastUpdate = new Date().toISOString();
        if(liveOk>0) saveCache();
        renderAll();
        if(manual) toast(liveOk>0 ? 'Dashboard aktualisiert.' : 'Gerade keine Live-Werte erreichbar.');
      }
    }catch(e){loadCache(); state.fromCache=true; renderAll(); toast('Aktualisierung nicht vollständig. Letzter Stand bleibt sichtbar.');}
    finally{setLoading(false);}
  }

  function avgPct(arr,filter=()=>true){const vals=arr.filter(x=>x.ok!==false && filter(x)).map(x=>safeNum(x.changePct)).filter(v=>v!==null);return vals.length ? vals.reduce((a,b)=>a+b,0)/vals.length : null;}
  function loadedCount(arr){return arr.filter(x=>x.ok!==false && safeNum(x.price)!==null).length;}
  function latestTime(items){const times=items.map(x=>x.marketTime||x.updatedAt).filter(Boolean).map(x=>+new Date(x)).filter(Number.isFinite);return times.length ? new Date(Math.max(...times)).toISOString() : null;}

  function renderGlobal(){
    els.globalUpdate.textContent = state.lastUpdate ? fmtTime(state.lastUpdate) : 'Noch kein Update';
    els.globalUpdateSub.textContent = state.fromCache ? 'Letzter gespeicherter Stand.' : (state.lastUpdate ? 'Alle Bereiche wurden neu berechnet.' : 'Beim Öffnen wird automatisch aktualisiert.');
    const total = STOCKS.length + MACROS.length + 1 + 1 + AIRPORTS.length;
    const ok = loadedCount(state.stocks)+loadedCount(state.macros)+(state.jetFuel?1:0)+(state.opensky?1:0)+state.metars.filter(x=>x.ok).length;
    let label='Live'; let clsName='good'; let sub='Daten aktualisiert.';
    if(!state.lastUpdate){label='Initialisierung';clsName='warn';sub='Live-Daten werden geladen.';}
    else if(ok===0){label='Offline';clsName='bad';sub='Keine Live-Werte erreichbar.';}
    else if(ok<Math.round(total*.55)){label='Teilweise';clsName='warn';sub='Ein Teil der Werte ist geladen.';}
    else if(ok<total){label='Live / teilweise';clsName='warn';sub='Marktüberblick ist nutzbar; einzelne Werte fehlen.';}
    els.dataStatus.textContent=label; els.dataStatus.className='big '+clsName; els.dataStatusSub.textContent=sub; els.liveLabel.textContent = label.includes('Live') ? 'Live Marktüberblick' : 'Marktüberblick';
  }

  function renderKPIs(){
    const basket = avgPct(state.stocks);
    const airlines = avgPct(state.stocks,x=>x.segment==='Airline');
    const industrials = avgPct(state.stocks,x=>x.segment==='OEM'||x.segment==='Supplier');
    const airports = avgPct(state.stocks,x=>x.segment==='Airport');
    const brent = state.macros.find(x=>x.symbol==='BZ=F');
    const eur = state.macros.find(x=>x.symbol==='EURUSD=X');
    const ops = state.opensky;
    const cards = [
      ['Aviation Basket', pct(basket), `${loadedCount(state.stocks)}/${STOCKS.length} Werte`, cls(basket)],
      ['Airlines', pct(airlines), 'Europa Airline Basket', cls(airlines)],
      ['OEM & Supplier', pct(industrials), 'Airbus, Boeing, MTU, Safran …', cls(industrials)],
      ['Airports', pct(airports), 'Fraport, Wien, ADP, Aena', cls(airports)],
      ['Brent', brent && safeNum(brent.price)!==null ? num(brent.price) : '–', brent ? pct(brent.changePct) : 'Fuel', brent ? cls(brent.changePct) : 'neutral'],
      ['EUR/USD', eur && safeNum(eur.price)!==null ? num4(eur.price) : '–', eur ? pct(eur.changePct) : 'FX', eur ? cls(eur.changePct) : 'neutral']
    ];
    els.kpiArea.innerHTML = cards.map(c=>`<div class="kpi"><div class="name">${esc(c[0])}</div><div class="val ${c[3]}">${esc(c[1])}</div><div class="sub">${esc(c[2])}</div></div>`).join('');
  }

  function renderTicker(){
    const items = [...state.stocks, ...state.macros].filter(x=>x.ok!==false && safeNum(x.price)!==null).slice(0,34);
    const html = items.map(x=>`<div class="tickerItem"><b>${esc(x.name||x.symbol)}</b><span>${esc((x.currency==='GBp'||x.currency==='GBP')?num(x.price):num(x.price))}</span><span class="${cls(x.changePct)}">${esc(pct(x.changePct))}</span></div>`).join('');
    els.tickerTrack.innerHTML = html ? html + html : '<div class="tickerItem">Marktdaten werden geladen …</div>';
  }

  function renderFilters(){
    const filters = ['Alle','Airline','OEM','Supplier','Airport','Deutschland','Österreich','Europa'];
    els.filters.innerHTML = filters.map(f=>`<button class="pill ${state.activeFilter===f?'active':''}" data-filter="${esc(f)}">${esc(f)}</button>`).join('');
    els.filters.querySelectorAll('button').forEach(btn=>btn.onclick=()=>{state.activeFilter=btn.dataset.filter;renderFilters();renderStocks();});
  }
  function matchesFilter(x){const f=state.activeFilter;if(f==='Alle')return true;if(['Airline','OEM','Supplier','Airport'].includes(f))return x.segment===f;return x.focus===f;}
  function renderStocks(){
    const q=state.query.trim().toLowerCase();
    const rows=state.stocks.filter(matchesFilter).filter(x=>!q || [x.symbol,x.name,x.segment,x.focus,x.aliases].join(' ').toLowerCase().includes(q));
    els.equityCount.textContent = `${loadedCount(rows)}/${rows.length} Werte`;
    const latest = latestTime(state.stocks);
    els.lastStockUpdate.textContent = latest ? `Letztes Aktien-Update: ${fmtTime(latest)}` : 'Letztes Aktien-Update: –';
    if(!rows.length){els.stockBody.innerHTML='<tr><td colspan="8"><div class="empty">Keine passenden Werte.</div></td></tr>';return;}
    els.stockBody.innerHTML = rows.map(x=>{
      const price = safeNum(x.price)!==null ? `${num(x.price)} ${esc(x.currency||'')}` : '–';
      const vol = safeNum(x.volume)!==null ? num0(x.volume) : '–';
      const initials = x.name.split(/\s|-/).filter(Boolean).slice(0,2).map(s=>s[0]).join('').toUpperCase();
      return `<tr><td><div class="company"><div class="avatar">${esc(initials)}</div><div><b>${esc(x.name)}</b><div class="small">${esc(x.symbol)}</div></div></div></td><td><span class="tag">${esc(x.segment)}</span></td><td>${esc(x.focus)}</td><td><b>${price}</b></td><td class="${cls(x.changePct)}"><b>${esc(pct(x.changePct))}</b><div class="small">${esc(num(x.change))}</div></td><td>${esc(vol)}</td><td>${esc(fmtShort(x.marketTime||x.updatedAt))}</td><td><span class="tag">${esc(x.marketState || (x.ok===false?'n/a':'–'))}</span></td></tr>`;
    }).join('');
  }

  function renderPulse(){
    const okStocks = state.stocks.filter(x=>x.ok!==false && safeNum(x.changePct)!==null);
    const best = okStocks.slice().sort((a,b)=>b.changePct-a.changePct)[0];
    const worst = okStocks.slice().sort((a,b)=>a.changePct-b.changePct)[0];
    const dach = avgPct(state.stocks,x=>x.focus==='Deutschland'||x.focus==='Österreich');
    const global = avgPct(state.stocks);
    els.pulseCards.innerHTML = [
      ['Top Mover', best ? best.name : '–', best ? pct(best.changePct) : '–', best?cls(best.changePct):'neutral'],
      ['Weakest', worst ? worst.name : '–', worst ? pct(worst.changePct) : '–', worst?cls(worst.changePct):'neutral'],
      ['DACH Basket', pct(dach), 'Deutschland & Österreich', cls(dach)],
      ['Europe Basket', pct(global), 'Gesamte Watchlist', cls(global)]
    ].map(c=>`<div class="mini"><div class="name">${esc(c[0])}</div><div class="num ${c[3]}" style="font-size:20px">${esc(c[1])}</div><div class="desc">${esc(c[2])}</div></div>`).join('');
    const groups = ['Airline','OEM','Supplier','Airport'].map(g=>({g,v:avgPct(state.stocks,x=>x.segment===g),n:state.stocks.filter(x=>x.ok!==false&&x.segment===g&&safeNum(x.price)!==null).length}));
    els.sectorBars.innerHTML = groups.map(x=>{const width=x.v===null?50:Math.max(0,Math.min(100,50+x.v*9));return `<div class="barrow"><div class="barlabel">${esc(x.g)} · ${x.n}</div><div class="bartrack"><div class="barfill" style="width:${width}%"></div></div><b class="${cls(x.v)}">${esc(pct(x.v))}</b></div>`;}).join('');
  }

  function renderFuel(){
    const brent=state.macros.find(x=>x.symbol==='BZ=F'), wti=state.macros.find(x=>x.symbol==='CL=F'), heat=state.macros.find(x=>x.symbol==='HO=F'), eur=state.macros.find(x=>x.symbol==='EURUSD=X');
    const jet=state.jetFuel;
    els.fuelUpdated.textContent = `Update: ${fmtTime(latestTime([...state.macros, jet||{}]))}`;
    const cards = [
      ['Jet Fuel Spot', jet ? num(jet.value) : '–', jet ? `USD/gal · ${pct(jet.changePct)} · ${jet.date}` : '–', jet?cls(jet.changePct):'neutral'],
      ['Brent', brent&&safeNum(brent.price)!==null?num(brent.price):'–', brent?pct(brent.changePct):'–', brent?cls(brent.changePct):'neutral'],
      ['Heating Oil', heat&&safeNum(heat.price)!==null?num(heat.price):'–', heat?pct(heat.changePct):'–', heat?cls(heat.changePct):'neutral'],
      ['EUR/USD', eur&&safeNum(eur.price)!==null?num4(eur.price):'–', eur?pct(eur.changePct):'–', eur?cls(eur.changePct):'neutral']
    ];
    els.fuelCards.innerHTML = cards.map(c=>`<div class="mini"><div class="name">${esc(c[0])}</div><div class="num ${c[3]}">${esc(c[1])}</div><div class="desc">${esc(c[2])}</div></div>`).join('');
    const macroRows = [...(jet?[{name:'Jet Fuel Spot', price:jet.value, changePct:jet.changePct, unit:'USD/gal', marketTime:jet.updatedAt}]:[]), ...state.macros].filter(x=>x && (x.name));
    els.macroBody.innerHTML = macroRows.length ? macroRows.map(x=>`<tr><td><b>${esc(x.name)}</b></td><td>${esc((x.symbol==='EURUSD=X')?num4(x.price):num(x.price||x.value))} ${esc(x.currency||x.unit||'')}</td><td class="${cls(x.changePct)}"><b>${esc(pct(x.changePct))}</b></td><td>${esc(fmtShort(x.marketTime||x.updatedAt))}</td></tr>`).join('') : '<tr><td colspan="4"><div class="empty">Noch keine Fuel-/Macro-Daten.</div></td></tr>';
  }

  function renderOps(){
    const sky=state.opensky;
    els.opsUpdated.textContent = `Update: ${fmtTime((sky&&sky.updatedAt) || latestTime(state.metars))}`;
    const ops = [
      ['Europa airborne', sky ? String(sky.airborne) : '–', 'Live-Flugbewegungen'],
      ['Deutschland', sky ? String(sky.de) : '–', 'Airborne im DE-Fokus'],
      ['Österreich', sky ? String(sky.at) : '–', 'Airborne im AT-Fokus']
    ];
    els.opsCards.innerHTML = ops.map(o=>`<div class="mini"><div class="name">${esc(o[0])}</div><div class="num">${esc(o[1])}</div><div class="desc">${esc(o[2])}</div></div>`).join('');
    els.metarList.innerHTML = state.metars.length ? state.metars.map(m=>`<div class="metar"><div class="metarTop"><b>${esc(m.id)} · ${esc(m.name)}</b><span class="tag">${m.ok?esc(m.category):'–'}</span></div>${m.ok?`<div class="small">Temp: ${num(m.temp)} °C · Wind: ${esc(m.wind)} kt · Sicht: ${esc(m.visib)}</div><div class="raw">${esc(m.raw)}</div>`:`<div class="small">Aktuell kein Wetterwert.</div>`}</div>`).join('') : '<div class="empty">Noch keine Airport-Wetterdaten.</div>';
  }

  function renderAll(){renderGlobal();renderKPIs();renderTicker();renderFilters();renderStocks();renderPulse();renderFuel();renderOps();}
  function setupAutoRefresh(){clearInterval(refreshTimer);const ms=Number(els.refreshSelect.value||0);if(ms>0)refreshTimer=setInterval(()=>updateDashboard(false),ms);}
  function init(){applySettings();els.updateBtn.onclick=()=>updateDashboard(true);els.themeBtn.onclick=()=>{settings.theme=settings.theme==='light'?'dark':'light';saveSettings();applySettings();};els.refreshSelect.onchange=setupAutoRefresh;els.searchInput.oninput=e=>{state.query=e.target.value;renderStocks();};renderAll();loadCache();setupAutoRefresh();updateDashboard(false);}
  init();
})();
</script>
