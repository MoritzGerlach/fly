            <tbody id="stockBody"></tbody>
          </table>
        </div>
      </section>

      <section class="panel">
        <div class="head"><div><h3>Market Pulse</h3><div class="hint">Durchschnittliche Tagesbewegung nach Segment.</div></div></div>
        <div class="miniGrid" id="pulseCards"></div>
        <div class="barArea" id="sectorBars"></div>
